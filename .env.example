# --- App ---
NEXT_PUBLIC_SITE_URL=https://www.tertiaryinfotech.com

# --- Postgres (Coolify-provisioned) ---
DATABASE_URL=postgres://user:pass@localhost:5432/tertiaryinfotech

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Seeded on first run by `pnpm seed:admin`
ADMIN_EMAIL=admin@tertiaryinfotech.com
ADMIN_PASSWORD=change-me-immediately

# --- Gmail OAuth2 (for contact / lead form delivery) ---
GMAIL_USER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
LEAD_NOTIFICATION_EMAIL=sales@tertiarycourses.com.sg

# --- Public chatbot (Gemini) ---
GEMINI_API_KEY=

# --- Admin AI Assist (Claude Agent SDK via OAuth subscription token) ---
# Generate locally with: `claude setup-token` (uses your Claude Max subscription)
# Stored server-side only. Never expose to the browser.
ANTHROPIC_AUTH_TOKEN=
